  <!-- OFFERINGS — ink field; pillar accents from the PRIMARIES: red / yellow / green. -->
  <section class="card dark offerings tall nopin" id="offerings" data-nav="dark" data-navbg="#231F20">
    <div class="wrap">
      <h2 class="head reveal d1" data-m style="margin-bottom:clamp(30px,4vw,64px)">{{ offerings.heading | safe }}</h2>
{% for item in offerings.items %}
      <article class="offer reveal" id="{{ item.id }}" style="--co:{{ item.accentColor }}">
        <!-- card photos and the Read-more pop-up pages are independent lists;
             operators manage each on its own -->
        <div class="oshot" data-photos="{{ item.photos | join(',') }}">
          <span class="idx">1/{{ item.photos | length }}</span>
        </div>
        <div class="otext" data-m>
          <h3>{{ item.title | safe }}</h3>
          <p>{{ item.copy | safe }}</p>
{%- if item.partnerLede %}
          <p class="partner">{{ item.partnerLede }}</p>
          <ul class="offer-list">
{% for li in item.partnerList %}            <li>{{ li | safe }}</li>
{% endfor %}          </ul>
{%- endif %}
          <a class="more" href="{{ item.linkHref }}"{% if item.linkScroll %} data-scroll{% endif %}>{{ item.linkLabel }}</a>
        </div>
      </article>
{% endfor %}    </div>
  </section>

